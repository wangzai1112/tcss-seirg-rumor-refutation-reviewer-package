			<StartupCode><![CDATA[int n = people.size();

// 使用虚拟时间运行，减少批量补实验等待时间。
getEngine().setRealTimeMode(false);

// 使 seedId 真正控制本次仿真的默认随机数流，支撑多 seed 重复实验的可复现性。
getEngine().setDefaultRandomGenerator(new java.util.Random(seedId));

// 每次仿真启动时先关闭手动按钮状态；批量实验通过 enableOnline/OfflineIntervention 与 interventionStartTime 控制。
isOnlineIntervention = false;
isOfflineIntervention = false;

// 拓扑参数由界面/实验参数控制，便于做结构敏感性与稳健性实验。
int k_offline = Math.max(0, kOffline);
if (k_offline % 2 != 0) k_offline += 1;
int k_online = Math.max(0, kOnline);
if (k_online % 2 != 0) k_online += 1;
double p_rewire = Math.max(0.0, Math.min(1.0, pRewire));

// ==========================================
// 第一阶段：构建线下规则网络 (Regular Ring Lattice)
// ==========================================
for (int i = 0; i < n; i++) {
    Person p = people.get(i);
    for (int j = 1; j <= k_offline / 2; j++) {
        int targetIndex = (i + j) % n;
        Person target = people.get(targetIndex);
        if (!p.offlineConnections.isConnectedTo(target)) {
            p.offlineConnections.connectTo(target);
        }
    }
}

// ==========================================
// 第二阶段：构建线上WS小世界网络 (Watts-Strogatz)
// ==========================================
for (int i = 0; i < n; i++) {
    Person p = people.get(i);
    for (int j = 1; j <= k_online / 2; j++) {
        int targetIndex = (i + j) % n;
        Person target = people.get(targetIndex);
        if (!p.onlineConnections.isConnectedTo(target)) {
            p.onlineConnections.connectTo(target);
        }
    }
}

// 执行边重连，拒绝自环与重边。
for (int i = 0; i < n; i++) {
    Person p = people.get(i);
    List<Person> currentOnlineNeighbors = new ArrayList<>(p.onlineConnections.getConnections());

    for (Person neighbor : currentOnlineNeighbors) {
        if (p.getIndex() < neighbor.getIndex() && randomTrue(p_rewire)) {
            p.onlineConnections.disconnectFrom(neighbor);

            Person newTarget = people.random();
            int guard = 0;
            while ((newTarget == p || p.onlineConnections.isConnectedTo(newTarget)) && guard < n * 2) {
                newTarget = people.random();
                guard++;
            }

            if (newTarget != p && !p.onlineConnections.isConnectedTo(newTarget)) {
                p.onlineConnections.connectTo(newTarget);
            } else {
                p.onlineConnections.connectTo(neighbor);
            }
        }
    }
}

// ==========================================
// 第三阶段：随机抽取初始感染种子，避免固定前20个主体带来的位置偏差
// ==========================================
java.util.HashSet<Person> seeded = new java.util.HashSet<Person>();
int onlineSeeds = Math.min(Math.max(0, initialOnlineSeeds), n);

for (int s = 0; s < onlineSeeds; s++) {
    Person candidate = people.random();
    int guard = 0;
    while (seeded.contains(candidate) && guard < n * 2) {
        candidate = people.random();
        guard++;
    }
    if (!seeded.contains(candidate)) {
        seeded.add(candidate);
        candidate.receive("线上初始感染");
    }
}

int offlineSeeds = Math.min(Math.max(0, initialOfflineSeeds), n - seeded.size());
for (int s = 0; s < offlineSeeds; s++) {
    Person candidate = people.random();
    int guard = 0;
    while (seeded.contains(candidate) && guard < n * 2) {
        candidate = people.random();
        guard++;
    }
    if (!seeded.contains(candidate)) {
        seeded.add(candidate);
        candidate.receive("线下初始感染");
    }
}


if (enableCsvExport) {
    final Main self = this;
    final double finalTimeForCsv = 180.0;
    final java.io.File outputDir = new java.io.File("/Users/hao/2026/Codex/6月/毕业论文/AnyLogic输出数据");
    outputDir.mkdirs();
    final int csvKOffline = k_offline;
    final int csvKOnline = k_online;
    final double csvPRewire = p_rewire;
    final int csvOnlineSeeds = onlineSeeds;
    final int csvOfflineSeeds = offlineSeeds;

    final String runId = "M" + modelMode
        + "_T" + Math.round(interventionStartTime)
        + "_on" + enableOnlineIntervention
        + "_off" + enableOfflineIntervention
        + "_seed" + seedId
        + "_kon" + csvKOnline
        + "_koff" + csvKOffline
        + "_rewire" + String.valueOf(csvPRewire).replace('.', 'p')
        + "_or" + String.valueOf(线上传播速率).replace('.', 'p')
        + "_fr" + String.valueOf(线下传播速率).replace('.', 'p')
        + "_gOn" + String.valueOf(线上辟谣影响系数).replace('.', 'p')
        + "_gOff" + String.valueOf(线下辟谣影响系数).replace('.', 'p')
        + "_" + System.currentTimeMillis();

    try {
        final java.io.PrintWriter rawWriter = new java.io.PrintWriter(
            new java.io.OutputStreamWriter(
                new java.io.FileOutputStream(new java.io.File(outputDir, "raw_timeseries_" + runId + ".csv")),
                "UTF-8"
            )
        );
        final java.io.PrintWriter summaryWriter = new java.io.PrintWriter(
            new java.io.OutputStreamWriter(
                new java.io.FileOutputStream(new java.io.File(outputDir, "summary_metrics_" + runId + ".csv")),
                "UTF-8"
            )
        );
        final java.io.PrintWriter parameterWriter = new java.io.PrintWriter(
            new java.io.OutputStreamWriter(
                new java.io.FileOutputStream(new java.io.File(outputDir, "parameter_master_" + runId + ".csv")),
                "UTF-8"
            )
        );

        rawWriter.println("runId,time,S,E,I1,I2,G1,G2,R,modelMode,interventionStartTime,enableOnlineIntervention,enableOfflineIntervention,kOffline,kOnline,pRewire,initialOnlineSeeds,initialOfflineSeeds,seedId");
        summaryWriter.println("runId,modelMode,seedId,interventionStartTime,enableOnlineIntervention,enableOfflineIntervention,kOffline,kOnline,pRewire,initialOnlineSeeds,initialOfflineSeeds,I1Peak,I1PeakTime,I2Peak,I2PeakTime,G1Peak,G2Peak,cumulativeInfectedPersonHours,finalS,finalE,finalI1,finalI2,finalG1,finalG2,finalR");
        parameterWriter.println("runId,modelMode,seedId,interventionStartTime,enableOnlineIntervention,enableOfflineIntervention,kOffline,kOnline,pRewire,initialOnlineSeeds,initialOfflineSeeds,onlineRate,offlineRate,onlineGovEffect,offlineGovEffect,latentTime,forgetTime,govForgetTime");
        summaryWriter.flush();
        parameterWriter.println(runId + "," + modelMode + "," + seedId + "," + interventionStartTime + "," + enableOnlineIntervention + "," + enableOfflineIntervention + "," + csvKOffline + "," + csvKOnline + "," + csvPRewire + "," + csvOnlineSeeds + "," + csvOfflineSeeds + "," + 线上传播速率 + "," + 线下传播速率 + "," + 线上辟谣影响系数 + "," + 线下辟谣影响系数 + "," + 潜伏时间 + "," + 遗忘时间 + "," + 辟谣者遗忘时间);
        parameterWriter.flush();

        final double[] lastTime = new double[] { self.time() };
        final double[] i1Peak = new double[] { 0.0 };
        final double[] i1PeakTime = new double[] { 0.0 };
        final double[] i2Peak = new double[] { 0.0 };
        final double[] i2PeakTime = new double[] { 0.0 };
        final double[] g1Peak = new double[] { 0.0 };
        final double[] g2Peak = new double[] { 0.0 };
        final double[] cumulativeInfectedPersonHours = new double[] { 0.0 };

        class CsvRecorder extends com.anylogic.engine.DynamicEvent {
            CsvRecorder(double dt) {
                super(self, dt, com.anylogic.engine.TimeUnits.HOUR);
            }

            @Override
            public void execute() {
                double t = self.time();
                int sCount = self.people.Susceptible();
                int eCount = self.people.Exposed();
                int i1Count = self.people.OnlineInfected();
                int i2Count = self.people.OfflineInfected();
                int g1Count = self.people.ONOfficeRecovered();
                int g2Count = self.people.OFFOfficeRecovered();
                int rCount = self.people.Recovered();

                double dt = Math.max(0.0, t - lastTime[0]);
                cumulativeInfectedPersonHours[0] += (i1Count + i2Count) * dt;
                lastTime[0] = t;

                if (i1Count > i1Peak[0]) {
                    i1Peak[0] = i1Count;
                    i1PeakTime[0] = t;
                }
                if (i2Count > i2Peak[0]) {
                    i2Peak[0] = i2Count;
                    i2PeakTime[0] = t;
                }
                if (g1Count > g1Peak[0]) g1Peak[0] = g1Count;
                if (g2Count > g2Peak[0]) g2Peak[0] = g2Count;

                rawWriter.println(runId + "," + t + "," + sCount + "," + eCount + "," + i1Count + "," + i2Count + "," + g1Count + "," + g2Count + "," + rCount + "," + modelMode + "," + interventionStartTime + "," + enableOnlineIntervention + "," + enableOfflineIntervention + "," + csvKOffline + "," + csvKOnline + "," + csvPRewire + "," + csvOnlineSeeds + "," + csvOfflineSeeds + "," + seedId);
                rawWriter.flush();

                if (t + 1.0e-9 < finalTimeForCsv) {
                    new CsvRecorder(Math.min(1.0, finalTimeForCsv - t));
                } else {
                    summaryWriter.println(runId + "," + modelMode + "," + seedId + "," + interventionStartTime + "," + enableOnlineIntervention + "," + enableOfflineIntervention + "," + csvKOffline + "," + csvKOnline + "," + csvPRewire + "," + csvOnlineSeeds + "," + csvOfflineSeeds + "," + i1Peak[0] + "," + i1PeakTime[0] + "," + i2Peak[0] + "," + i2PeakTime[0] + "," + g1Peak[0] + "," + g2Peak[0] + "," + cumulativeInfectedPersonHours[0] + "," + sCount + "," + eCount + "," + i1Count + "," + i2Count + "," + g1Count + "," + g2Count + "," + rCount);
                    summaryWriter.flush();
                    rawWriter.close();
                    summaryWriter.close();
                    parameterWriter.close();
                    traceln("CSV导出完成：" + runId);
                    finishSimulation();
                }
            }
        }

        new CsvRecorder(0.0);
        traceln("CSV导出已启动：" + runId);
    } catch (Exception ex) {
        traceln("CSV导出初始化失败：" + ex.getMessage());
    }
}
traceln("SCI补实验版：双层网络已生成，kOffline=" + k_offline
    + ", kOnline=" + k_online
    + ", pRewire=" + p_rewire
    + ", onlineSeeds=" + onlineSeeds
    + ", offlineSeeds=" + offlineSeeds
    + ", interventionStartTime=" + interventionStartTime
    + ", modelMode=" + modelMode
    + ", seedId=" + seedId);]]></StartupCode>
